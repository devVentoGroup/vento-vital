{
  "name": "vento-vital",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "node apps/api/src/server.js",
    "dev:mobile": "npm --prefix apps/mobile run start",
    "build:dev:ios": "npm --prefix apps/mobile run eas:build:dev:ios",
    "build:prod:android": "npm --prefix apps/mobile run eas:build:prod:android",
    "build:prod:ios": "npm --prefix apps/mobile run eas:build:prod:ios",
    "test:contracts:api": "npm --prefix apps/api run test:contracts",
    "ci:contracts": "npm run test:contracts:api"
  }
}
