{
  "expo": {
    "name": "Vento Vital",
    "slug": "vento-vital",
    "scheme": "vento-vital",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ventogroup.vital"
    },
    "android": {
      "package": "com.ventogroup.vital"
    },
    "plugins": [
      "expo-secure-store",
      "expo-notifications"
    ]
  }
}
